// ============================================================
// 跨地域关系（用于AI推演时的合理性判断）
// ============================================================
const REGION_RELATIONS = {
  '渊-渊东共和国': { relation: '盟友', desc: '贸易伙伴，人员往来频繁，联合里界探索' },
